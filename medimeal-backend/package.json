{
  "name": "medimeal-backend",
  "version": "1.0.0",
  "description": "MediMeal Backend API for personalized medication-based meal recommendations",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed:admin": "node scripts/seed-admin.js",
    "admin:reset": "node scripts/admin-reset.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "blockchain:deploy": "cd blockchain && npx hardhat run scripts/deploy.js --network mumbai",
    "blockchain:deploy:local": "cd blockchain && npx hardhat run scripts/deploy.js --network hardhat",
    "blockchain:compile": "cd blockchain && npx hardhat compile"
  },
  "keywords": [
    "healthcare",
    "nutrition",
    "medication",
    "meal-planning",
    "api"
  ],
  "author": "MediMeal Team",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "firebase-admin": "^12.0.0",
    "framer-motion": "^12.23.12",
    "google-auth-library": "^10.3.0",
    "helmet": "^7.1.0",
    "ipfs-http-client": "^60.0.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.542.0",
    "mongoose": "^7.6.3",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.15",
    "pdfkit": "^0.17.2",
    "razorpay": "^2.9.6"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "hardhat": "^2.19.0",
    "nodemon": "^3.0.2"
  }
}
