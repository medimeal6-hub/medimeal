   "metadata": {
    "id": "deep_learning_recommender"
   },
   "outputs": [],
   "source": [
    "# Deep Learning Recommendation System\\n",
    "def create_deep_recommender_model(n_users, n_items, n_factors=50):\\n",
    "    # User and item inputs\\n",
    "    user_input = keras.Input(shape=(), name='user_id')\\n",
    "    item_input = keras.Input(shape=(), name='item_id')\\n",
    "    \\n",
    "    # Embedding layers\\n",
    "    user_embedding = layers.Embedding(n_users, n_factors, name='user_embedding')(user_input)\\n",
    "    item_embedding = layers.Embedding(n_items, n_factors, name='item_embedding')(item_input)\\n",
    "    \\n",
    "    # Flatten embeddings\\n",
    "    user_vec = layers.Flatten()(user_embedding)\\n",
    "    item_vec = layers.Flatten()(item_embedding)\\n",
    "    \\n",
    "    # Concatenate user and item vectors\\n",
    "    concat = layers.Concatenate()([user_vec, item_vec])\\n",
    "    \\n",
    "    # Deep neural network\\n",
    "    dense1 = layers.Dense(128, activation='relu')(concat)\\n",
    "    dropout1 = layers.Dropout(0.3)(dense1)\\n",
    "    dense2 = layers.Dense(64, activation='relu')(dropout1)\\n",
    "    dropout2 = layers.Dropout(0.3)(dense2)\\n",
    "    dense3 = layers.Dense(32, activation='relu')(dropout2)\\n",
    "    \\n",
    "    # Output layer\\n",
    "    output = layers.Dense(1, activation='sigmoid')(dense3)\\n",
    "    output = layers.Lambda(lambda x: x * 4 + 1)(output)  # Scale to 1-5 range\\n",
    "    \\n",
    "    model = keras.Model(inputs=[user_input, item_input], outputs=output)\\n",
    "    model.compile(optimizer='adam', loss='mse', metrics=['mae'])\\n",
    "    \\n",
    "    return model\\n",
    "\\n",
    "# Prepare data for deep learning model\\n",
    "def prepare_dl_data(interactions_df):\\n",
    "    user_encoder = LabelEncoder()\\n",
    "    item_encoder = LabelEncoder()\\n",
    "    \\n",
    "    interactions_df['user_idx'] = user_encoder.fit_transform(interactions_df['user_id'])\\n",
    "    interactions_df['item_idx'] = item_encoder.fit_transform(interactions_df['meal_id'])\\n",
    "    \\n",
    "    X = {\\n",
    "        'user_id': interactions_df['user_idx'].values,\\n",
    "        'item_id': interactions_df['item_idx'].values\\n",
    "    }\\n",
    "    y = interactions_df['rating'].values\\n",
    "    \\n",
    "    return X, y, user_encoder, item_encoder\\n",
    "\\n",
    "# Prepare data\\n",
    "X, y, user_enc, item_enc = prepare_dl_data(interactions_df)\\n",
    "\\n",
    "# Split data\\n",
    "X_train, X_test, y_train, y_test = train_test_split(\\n",
    "    [X['user_id'], X['item_id']], y, test_size=0.2, random_state=42\\n",
    ")\\n",
    "\\n",
    "# Create and train model\\n",
    "n_users = len(user_enc.classes_)\\n",
    "n_items = len(item_enc.classes_)\\n",
    "\\n",
    "dl_model = create_deep_recommender_model(n_users, n_items)\\n",
    "\\n",
    "# Train the model\\n",
    "history = dl_model.fit(\\n",
    "    {'user_id': X_train[0], 'item_id': X_train[1]}, y_train,\\n",
    "    validation_data=({'user_id': X_test[0], 'item_id': X_test[1]}, y_test),\\n",
    "    epochs=20,\\n",
    "    batch_size=256,\\n",
    "    verbose=1\\n",
    ")\\n",
    "\\n",
    "# Evaluate model\\n",
    "test_loss, test_mae = dl_model.evaluate({'user_id': X_test[0], 'item_id': X_test[1]}, y_test)\\n",
    "print(f'Deep Learning Model - Test MAE: {test_mae:.4f}')"
   ]
  },
