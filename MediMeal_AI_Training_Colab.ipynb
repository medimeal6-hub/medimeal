    "ax1.set_ylabel('Mean Absolute Error (Lower is Better)')\\n",
    "ax1.set_ylim(0, max(mae_scores) * 1.2)\\n",
    "\\n",
    "# Add value labels on bars\\n",
    "for bar, score in zip(bars1, mae_scores):\\n",
