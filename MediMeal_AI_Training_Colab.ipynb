   "source": [
    "## 4. Health Risk Prediction System\\n",
    "Predicting health risks based on user profiles and dietary patterns"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "generate_health_data"
   },
   "outputs": [],
   "source": [
    "# Generate health risk dataset\\n",
    "def generate_health_risk_data(users_df, interactions_df, n_samples=3000):\\n",
    "    np.random.seed(42)\\n",
    "    \\n",
    "    health_data = []\\n",
    "    \\n",
    "    for _, user in users_df.iterrows():\\n",
    "        # Get user's meal consumption patterns\\n",
    "        user_interactions = interactions_df[interactions_df['user_id'] == user['user_id']]\\n",
    "        \\n",
    "        if len(user_interactions) > 0:\\n",
    "            # Calculate dietary patterns\\n",
    "            consumed_meals = user_interactions[user_interactions['consumed'] == True]['meal_id']\\n",
    "            \\n",
    "            if len(consumed_meals) > 0:\\n",
    "                meal_data = meals_df[meals_df['meal_id'].isin(consumed_meals)]\\n",
    "                \\n",
    "                avg_calories = meal_data['calories'].mean()\\n",
    "                avg_sodium = meal_data['sodium'].mean()\\n",
    "                avg_sugar = meal_data['sugar'].mean()\\n",
    "                avg_fat = meal_data['fat'].mean()\\n",
    "                \\n",
    "                # Calculate risk factors\\n",
    "                diabetes_risk = 0\\n",
    "                hypertension_risk = 0\\n",
    "                heart_disease_risk = 0\\n",
    "                \\n",
    "                # Age factor\\n",
    "                if user['age'] > 45:\\n",
    "                    diabetes_risk += 0.2\\n",
    "                    hypertension_risk += 0.3\\n",
    "                    heart_disease_risk += 0.25\\n",
    "                \\n",
    "                # BMI factor\\n",
    "                if user['bmi'] > 30:\\n",
    "                    diabetes_risk += 0.4\\n",
    "                    hypertension_risk += 0.3\\n",
    "                    heart_disease_risk += 0.3\\n",
    "                elif user['bmi'] > 25:\\n",
    "                    diabetes_risk += 0.2\\n",
    "                    hypertension_risk += 0.15\\n",
    "                    heart_disease_risk += 0.15\\n",
    "                \\n",
    "                # Dietary factors\\n",
    "                if avg_calories > 2500:\\n",
    "                    diabetes_risk += 0.15\\n",
    "                    heart_disease_risk += 0.1\\n",
    "                \\n",
    "                if avg_sodium > 2000:\\n",
    "                    hypertension_risk += 0.25\\n",
    "                    heart_disease_risk += 0.2\\n",
    "                \\n",
    "                if avg_sugar > 25:\\n",
    "                    diabetes_risk += 0.2\\n",
    "                \\n",
    "                if avg_fat > 25:\\n",
    "                    heart_disease_risk += 0.15\\n",
    "                \\n",
    "                # Activity level factor\\n",
    "                if user['activity_level'] == 'sedentary':\\n",
    "                    diabetes_risk += 0.1\\n",
    "                    hypertension_risk += 0.1\\n",
    "                    heart_disease_risk += 0.1\\n",
    "                \\n",
    "                # Existing conditions\\n",
    "                if user['health_conditions'] != 'none':\\n",
    "                    if user['health_conditions'] == 'diabetes':\\n",
    "                        diabetes_risk = 1.0\\n",
    "                    elif user['health_conditions'] == 'hypertension':\\n",
    "                        hypertension_risk = 1.0\\n",
    "                    elif user['health_conditions'] == 'heart_disease':\\n",
    "                        heart_disease_risk = 1.0\\n",
    "                \\n",
    "                # Add some noise\\n",
    "                diabetes_risk += np.random.normal(0, 0.1)\\n",
    "                hypertension_risk += np.random.normal(0, 0.1)\\n",
    "                heart_disease_risk += np.random.normal(0, 0.1)\\n",
    "                \\n",
    "                # Clamp to [0, 1]\\n",
    "                diabetes_risk = max(0, min(1, diabetes_risk))\\n",
    "                hypertension_risk = max(0, min(1, hypertension_risk))\\n",
    "                heart_disease_risk = max(0, min(1, heart_disease_risk))\\n",
    "                \\n",
    "                health_record = {\\n",
    "                    'user_id': user['user_id'],\\n",
    "                    'age': user['age'],\\n",
    "                    'gender': user['gender'],\\n",
    "                    'bmi': user['bmi'],\\n",
    "                    'activity_level': user['activity_level'],\\n",
    "                    'avg_calories': avg_calories,\\n",
    "                    'avg_sodium': avg_sodium,\\n",
    "                    'avg_sugar': avg_sugar,\\n",
    "                    'avg_fat': avg_fat,\\n",
    "                    'diabetes_risk': diabetes_risk,\\n",
    "                    'hypertension_risk': hypertension_risk,\\n",
    "                    'heart_disease_risk': heart_disease_risk,\\n",
    "                    'diabetes_high_risk': diabetes_risk > 0.6,\\n",
    "                    'hypertension_high_risk': hypertension_risk > 0.6,\\n",
    "                    'heart_disease_high_risk': heart_disease_risk > 0.6\\n",
    "                }\\n",
    "                health_data.append(health_record)\\n",
    "    \\n",
    "    return pd.DataFrame(health_data)\\n",
    "\\n",
    "# Generate health risk data\\n",
    "health_risk_df = generate_health_risk_data(users_df, interactions_df)\\n",
    "print(f'Generated health risk data for {len(health_risk_df)} users')\\n",
    "health_risk_df.head()"
   ]
  }
