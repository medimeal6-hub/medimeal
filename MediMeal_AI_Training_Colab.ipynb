   "metadata": {
    "id": "generate_interaction_data"
   },
   "outputs": [],
   "source": [
    "# Generate user-meal interaction data\\n",
    "def generate_interaction_dataset(users_df, meals_df, n_interactions=10000):\\n",
    "    np.random.seed(42)\\n",
    "    \\n",
    "    interactions = []\\n",
    "    for i in range(n_interactions):\\n",
    "        user_id = np.random.choice(users_df['user_id'])\\n",
    "        meal_id = np.random.choice(meals_df['meal_id'])\\n",
    "        \\n",
    "        # Get user and meal info\\n",
    "        user = users_df[users_df['user_id'] == user_id].iloc[0]\\n",
    "        meal = meals_df[meals_df['meal_id'] == meal_id].iloc[0]\\n",
    "        \\n",
    "        # Generate realistic rating based on compatibility\\n",
    "        base_rating = 3.0\\n",
    "        \\n",
    "        # Adjust based on dietary preferences\\n",
    "        if user['dietary_preference'] in meal['dietary_tags']:\\n",
    "            base_rating += 1.0\\n",
    "        \\n",
    "        # Adjust based on allergies\\n",
    "        if user['allergies'] in meal['allergens']:\\n",
    "            base_rating -= 2.0\\n",
    "        \\n",
    "        # Adjust based on calorie match\\n",
    "        calorie_diff = abs(meal['calories'] - user['target_calories'] / 3)  # Assuming 3 meals per day\\n",
    "        if calorie_diff < 100:\\n",
    "            base_rating += 0.5\\n",
    "        \\n",
    "        # Add some randomness\\n",
    "        rating = base_rating + np.random.normal(0, 0.5)\\n",
    "        rating = max(1, min(5, rating))  # Clamp to 1-5 range\\n",
    "        \\n",
    "        interaction = {\\n",
    "            'user_id': user_id,\\n",
    "            'meal_id': meal_id,\\n",
    "            'rating': rating,\\n",
    "            'consumed': rating > 3.0,  # Binary feedback\\n",
    "            'timestamp': datetime.now() - timedelta(days=np.random.randint(0, 365))\\n",
    "        }\\n",
    "        interactions.append(interaction)\\n",
    "    \\n",
    "    return pd.DataFrame(interactions)\\n",
    "\\n",
    "# Generate interaction dataset\\n",
    "interactions_df = generate_interaction_dataset(users_df, meals_df, 10000)\\n",
    "print(f'Generated {len(interactions_df)} user-meal interactions')\\n",
    "interactions_df.head()"
   ]
  }
