    "id": "train_interaction_classifier"
   },
   "outputs": [],
   "source": [
    "# Train drug-food interaction classifier\\n",
    "from sklearn.feature_extraction.text import TfidfVectorizer\\n",
    "from sklearn.naive_bayes import MultinomialNB\\n",
    "from sklearn.pipeline import Pipeline\\n",
    "\\n",
    "# Prepare text data\\n",
    "def prepare_interaction_text(df):\\n",
    "    # Create text features if not exists\\n",
    "    if 'text' not in df.columns:\\n",
    "        df['text'] = df['drug'] + ' ' + df['food']\\n",
    "    \\n",
    "    return df['text'], df['interaction'], df['severity']\\n",
    "\\n",
    "# Prepare data\\n",
    "texts, interactions, severities = prepare_interaction_text(drug_food_df)\\n",
    "\\n",
    "# Split data\\n",
    "X_train_text, X_test_text, y_train_int, y_test_int = train_test_split(\\n",
    "    texts, interactions, test_size=0.2, random_state=42, stratify=interactions\\n",
    ")\\n",
    "\\n",
    "# Create and train interaction detection pipeline\\n",
    "interaction_pipeline = Pipeline([\\n",
    "    ('tfidf', TfidfVectorizer(max_features=1000, ngram_range=(1, 2))),\\n",
    "    ('classifier', MultinomialNB())\\n",
    "])\\n",
    "\\n",
    "interaction_pipeline.fit(X_train_text, y_train_int)\\n",
    "\\n",
    "# Evaluate interaction detection\\n",
    "y_pred_int = interaction_pipeline.predict(X_test_text)\\n",
    "interaction_accuracy = accuracy_score(y_test_int, y_pred_int)\\n",
    "\\n",
    "print(f'Drug-Food Interaction Detection Accuracy: {interaction_accuracy:.4f}')\\n",
    "print('\\nClassification Report:')\\n",
    "print(classification_report(y_test_int, y_pred_int))\\n",
    "\\n",
    "# Train severity classifier (for interactions only)\\n",
    "interaction_data = drug_food_df[drug_food_df['interaction'] == True]\\n",
    "severity_texts = interaction_data['text'] if 'text' in interaction_data.columns else interaction_data['drug'] + ' ' + interaction_data['food']\\n",
    "severity_labels = interaction_data['severity']\\n",
    "\\n",
    "if len(severity_texts) > 10:  # Only train if we have enough data\\n",
    "    X_train_sev, X_test_sev, y_train_sev, y_test_sev = train_test_split(\\n",
    "        severity_texts, severity_labels, test_size=0.2, random_state=42\\n",
    "    )\\n",
    "    \\n",
    "    severity_pipeline = Pipeline([\\n",
    "        ('tfidf', TfidfVectorizer(max_features=500, ngram_range=(1, 2))),\\n",
    "        ('classifier', MultinomialNB())\\n",
    "    ])\\n",
    "    \\n",
    "    severity_pipeline.fit(X_train_sev, y_train_sev)\\n",
    "    y_pred_sev = severity_pipeline.predict(X_test_sev)\\n",
    "    severity_accuracy = accuracy_score(y_test_sev, y_pred_sev)\\n",
    "    \\n",
    "    print(f'\\nSeverity Classification Accuracy: {severity_accuracy:.4f}')\\n",
    "else:\\n",
    "    severity_pipeline = None\\n",
    "    print('\\nNot enough data for severity classification')\\n",
    "\\n",
    "# Test the interaction detection system\\n",
    "def test_interaction_detection(drug, food):\\n",
    "    test_text = f\\\"{drug} {food}\\\"\\n",
    "    has_interaction = interaction_pipeline.predict([test_text])[0]\\n",
    "    interaction_prob = interaction_pipeline.predict_proba([test_text])[0][1]\\n",
    "    \\n",
    "    result = {\\n",
    "        'drug': drug,\\n",
    "        'food': food,\\n",
    "        'has_interaction': has_interaction,\\n",
    "        'interaction_probability': interaction_prob\\n",
    "    }\\n",
    "    \\n",
    "    if has_interaction and severity_pipeline:\\n",
    "        severity = severity_pipeline.predict([test_text])[0]\\n",
    "        result['severity'] = severity\\n",
    "    \\n",
    "    return result\\n",
    "\\n",
    "# Test examples\\n",
    "test_cases = [\\n",
    "    ('warfarin', 'spinach'),\\n",
    "    ('simvastatin', 'grapefruit'),\\n",
    "    ('paracetamol', 'banana'),\\n",
    "    ('metformin', 'alcohol')\\n",
    "]\\n",
    "\\n",
    "print('\\nTesting Drug-Food Interaction Detection:')\\n",
    "for drug, food in test_cases:\\n",
    "    result = test_interaction_detection(drug, food)\\n",
    "    print(f\\\"{drug} + {food}: {result}\\\")"
   ]
