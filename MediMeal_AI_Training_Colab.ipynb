  {
   "cell_type": "markdown",
   "metadata": {
    "id": "enhanced_recommendation"
   },
   "source": [
    "## 3. Enhanced Meal Recommendation System\\n",
    "Building advanced recommendation models using multiple approaches"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "collaborative_filtering"
   },
   "outputs": [],
   "source": [
    "# Collaborative Filtering with Matrix Factorization\\n",
    "class CollaborativeFilteringRecommender:\\n",
    "    def __init__(self, n_factors=50, learning_rate=0.01, regularization=0.01, epochs=100):\\n",
    "        self.n_factors = n_factors\\n",
    "        self.learning_rate = learning_rate\\n",
    "        self.regularization = regularization\\n",
    "        self.epochs = epochs\\n",
    "        \\n",
    "    def fit(self, interactions_df):\\n",
    "        # Create user-item matrix\\n",
    "        self.user_encoder = LabelEncoder()\\n",
    "        self.item_encoder = LabelEncoder()\\n",
    "        \\n",
    "        interactions_df['user_idx'] = self.user_encoder.fit_transform(interactions_df['user_id'])\\n",
    "        interactions_df['item_idx'] = self.item_encoder.fit_transform(interactions_df['meal_id'])\\n",
    "        \\n",
    "        self.n_users = len(self.user_encoder.classes_)\\n",
    "        self.n_items = len(self.item_encoder.classes_)\\n",
    "        \\n",
    "        # Initialize factors\\n",
    "        self.user_factors = np.random.normal(0, 0.1, (self.n_users, self.n_factors))\\n",
    "        self.item_factors = np.random.normal(0, 0.1, (self.n_items, self.n_factors))\\n",
    "        self.user_bias = np.zeros(self.n_users)\\n",
    "        self.item_bias = np.zeros(self.n_items)\\n",
    "        self.global_bias = interactions_df['rating'].mean()\\n",
    "        \\n",
    "        # Training loop\\n",
    "        for epoch in range(self.epochs):\\n",
    "            for _, row in interactions_df.iterrows():\\n",
    "                user_idx = int(row['user_idx'])\\n",
    "                item_idx = int(row['item_idx'])\\n",
    "                rating = row['rating']\\n",
    "                \\n",
    "                # Predict rating\\n",
    "                pred = (self.global_bias + \\n",
    "                       self.user_bias[user_idx] + \\n",
    "                       self.item_bias[item_idx] + \\n",
    "                       np.dot(self.user_factors[user_idx], self.item_factors[item_idx]))\\n",
    "                \\n",
    "                error = rating - pred\\n",
    "                \\n",
    "                # Update factors\\n",
    "                user_factor = self.user_factors[user_idx].copy()\\n",
    "                \\n",
    "                self.user_factors[user_idx] += self.learning_rate * (error * self.item_factors[item_idx] - self.regularization * self.user_factors[user_idx])\\n",
    "                self.item_factors[item_idx] += self.learning_rate * (error * user_factor - self.regularization * self.item_factors[item_idx])\\n",
    "                \\n",
    "                self.user_bias[user_idx] += self.learning_rate * (error - self.regularization * self.user_bias[user_idx])\\n",
    "                self.item_bias[item_idx] += self.learning_rate * (error - self.regularization * self.item_bias[item_idx])\\n",
    "        \\n",
    "        print(f'Collaborative filtering model trained for {self.epochs} epochs')\\n",
    "    \\n",
    "    def predict(self, user_id, meal_id):\\n",
    "        try:\\n",
    "            user_idx = self.user_encoder.transform([user_id])[0]\\n",
    "            item_idx = self.item_encoder.transform([meal_id])[0]\\n",
    "            \\n",
    "            pred = (self.global_bias + \\n",
    "                   self.user_bias[user_idx] + \\n",
    "                   self.item_bias[item_idx] + \\n",
    "                   np.dot(self.user_factors[user_idx], self.item_factors[item_idx]))\\n",
    "            \\n",
    "            return max(1, min(5, pred))\\n",
    "        except ValueError:\\n",
    "            return self.global_bias\\n",
    "    \\n",
    "    def recommend(self, user_id, n_recommendations=10):\\n",
    "        try:\\n",
    "            user_idx = self.user_encoder.transform([user_id])[0]\\n",
    "            \\n",
    "            # Calculate scores for all items\\n",
    "            scores = (self.global_bias + \\n",
    "                     self.user_bias[user_idx] + \\n",
    "                     self.item_bias + \\n",
    "                     np.dot(self.user_factors[user_idx], self.item_factors.T))\\n",
    "            \\n",
    "            # Get top recommendations\\n",
    "            top_items = np.argsort(scores)[::-1][:n_recommendations]\\n",
    "            recommendations = []\\n",
    "            \\n",
    "            for item_idx in top_items:\\n",
    "                meal_id = self.item_encoder.inverse_transform([item_idx])[0]\\n",
    "                score = scores[item_idx]\\n",
    "                recommendations.append({'meal_id': meal_id, 'predicted_rating': score})\\n",
    "            \\n",
    "            return recommendations\\n",
    "        except ValueError:\\n",
    "            return []\\n",
    "\\n",
    "# Train collaborative filtering model\\n",
    "cf_model = CollaborativeFilteringRecommender(n_factors=50, epochs=50)\\n",
    "cf_model.fit(interactions_df)\\n",
    "\\n",
    "# Test recommendations\\n",
    "sample_user = users_df['user_id'].iloc[0]\\n",
    "recommendations = cf_model.recommend(sample_user, 5)\\n",
    "print(f'Recommendations for {sample_user}:')\\n",
    "for rec in recommendations:\\n",
    "    print(f'  {rec[\"meal_id\"]}: {rec[\"predicted_rating\"]:.2f}')"
   ]
  }
