   "source": [
    "# Generate user health profiles\\n",
    "def generate_user_dataset(n_users=2000):\\n",
    "    np.random.seed(42)\\n",
    "    \\n",
    "    conditions = ['diabetes', 'hypertension', 'heart_disease', 'obesity', 'none']\\n",
    "    activity_levels = ['sedentary', 'lightly_active', 'moderately_active', 'very_active']\\n",
    "    goals = ['weight_loss', 'weight_gain', 'maintenance', 'muscle_gain']\\n",
    "    \\n",
    "    users = []\\n",
    "    for i in range(n_users):\\n",
    "        age = np.random.randint(18, 80)\\n",
    "        gender = np.random.choice(['male', 'female'])\\n",
    "        \\n",
    "        # Generate realistic BMI distribution\\n",
    "        bmi = np.random.normal(25, 4)\\n",
    "        bmi = max(16, min(45, bmi))  # Clamp to realistic range\\n",
    "        \\n",
    "        user = {\\n",
    "            'user_id': f'USER_{i:04d}',\\n",
    "            'age': age,\\n",
    "            'gender': gender,\\n",
    "            'height': np.random.normal(170, 10),  # cm\\n",
    "            'weight': np.random.normal(70, 15),   # kg\\n",
    "            'bmi': bmi,\\n",
    "            'activity_level': np.random.choice(activity_levels),\\n",
    "            'health_goal': np.random.choice(goals),\\n",
    "            'health_conditions': np.random.choice(conditions),\\n",
    "            'allergies': np.random.choice(['none', 'dairy', 'nuts', 'gluten'], p=[0.7, 0.1, 0.1, 0.1]),\\n",
    "            'dietary_preference': np.random.choice(['none', 'vegetarian', 'vegan', 'keto'], p=[0.6, 0.2, 0.1, 0.1]),\\n",
    "            'target_calories': np.random.randint(1200, 3000),\\n",
    "            'target_protein': np.random.randint(50, 150),\\n",
    "            'target_carbs': np.random.randint(100, 300),\\n",
    "            'target_fat': np.random.randint(30, 100)\\n",
    "        }\\n",
    "        users.append(user)\\n",
    "    \\n",
    "    return pd.DataFrame(users)\\n",
    "\\n",
    "# Generate user dataset\\n",
    "users_df = generate_user_dataset(2000)\\n",
    "print(f'Generated {len(users_df)} user profiles')\\n",
    "users_df.head()"
   ]
