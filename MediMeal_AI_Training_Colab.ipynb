    "# Generate comprehensive meal dataset\\n",
    "def generate_meal_dataset(n_samples=5000):\\n",
    "    np.random.seed(42)\\n",
    "    \\n",
    "    meal_types = ['breakfast', 'lunch', 'dinner', 'snack']\\n",
    "    cuisines = ['indian', 'mediterranean', 'american', 'asian', 'mexican']\\n",
    "    dietary_tags = ['vegetarian', 'vegan', 'keto', 'diabetic-friendly', 'heart-healthy', 'gluten-free']\\n",
    "    allergens = ['dairy', 'nuts', 'gluten', 'soy', 'eggs', 'fish']\\n",
    "    \\n",
    "    data = []\\n",
    "    for i in range(n_samples):\\n",
    "        meal = {\\n",
    "            'meal_id': f'MEAL_{i:04d}',\\n",
    "            'name': f'Meal_{i}',\\n",
    "            'type': np.random.choice(meal_types),\\n",
    "            'cuisine': np.random.choice(cuisines),\\n",
    "            'calories': np.random.normal(400, 150),\\n",
    "            'protein': np.random.normal(25, 10),\\n",
    "            'carbs': np.random.normal(45, 15),\\n",
    "            'fat': np.random.normal(15, 8),\\n",
    "            'fiber': np.random.normal(8, 3),\\n",
    "            'sodium': np.random.normal(600, 200),\\n",
    "            'sugar': np.random.normal(12, 6),\\n",
    "            'prep_time': np.random.randint(10, 120),\\n",
    "            'difficulty': np.random.choice(['easy', 'medium', 'hard']),\\n",
    "            'rating': np.random.uniform(3.0, 5.0),\\n",
    "            'dietary_tags': np.random.choice(dietary_tags, size=np.random.randint(0, 3)).tolist(),\\n",
    "            'allergens': np.random.choice(allergens, size=np.random.randint(0, 2)).tolist()\\n",
    "        }\\n",
    "        data.append(meal)\\n",
    "    \\n",
    "    return pd.DataFrame(data)\\n",
    "\\n",
    "# Generate meal dataset\\n",
    "meals_df = generate_meal_dataset(5000)\\n",
    "print(f'Generated {len(meals_df)} meals')\\n",
    "meals_df.head()"
   ]
  }
